# docker-compose environment for Karya Vaani + WhatsApp comms server.
# Copy to .env (same folder as docker-compose.yml) and fill in.

# Shared secret between the backend and the comms server (keep private).
COMMS_API_KEY=change-me-shared-secret

# ---- Meta WhatsApp Cloud API ----
# From Meta for Developers > your app > WhatsApp > API Setup.
# Leave blank to run the gateway in mock mode (messages logged, not sent).
META_API_VERSION=v21.0
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=

# Webhook verification token — you choose this value, then enter the SAME
# value in the Meta dashboard webhook configuration screen.
META_VERIFY_TOKEN=karya-vaani-verify

# App secret enables X-Hub-Signature-256 validation of inbound webhooks.
META_APP_SECRET=
COMMS_VERIFY_SIGNATURE=false

# TEST ONLY: redirect every outbound WhatsApp message to this single
# number so nothing reaches real workers. Leave empty in production.
WHATSAPP_TEST_RECIPIENT=919500200300
