# ── comms-server configuration ───────────────────────────────────────────
# Copy to .env and fill in. With no Meta credentials the server runs in MOCK
# mode (messages are logged, not sent) so the whole stack still works.

PORT=4100

# Comma-separated allowed CORS origins, or * for any.
ALLOWED_ORIGINS=*

# Shared secret required on send endpoints (x-api-key header). Leave blank to
# disable auth (only on a trusted private network / container link).
COMMS_API_KEY=change-me-shared-secret

# Provider: aoc | meta | mock
WHATSAPP_PROVIDER=aoc

# ── AOC portal ("BOT API") WhatsApp gateway ─────────────────────────
# Docs: https://developers.aoc-portal.com/whatsapp/webhook
# API host of the portal (change if your account uses a different host).
AOC_BASE_URL=https://apis.aoc-portal.com
# Account API key (portal login -> API key). Sent as the `apikey` header.
AOC_API_KEY=
# Sender WhatsApp number = the "From Id" registered in the portal,
# digits only. KaryaVani number:
AOC_FROM_ID=918220099940
# Shared secret for inbound webhooks. In the portal webhook dialog
# (Whatsapp -> Utility & Template -> Webhook -> Add Configuration ->
# Add Headers) add the SAME header name/value configured here. Calls
# without it are rejected with 401. Leave the token empty to disable.
AOC_WEBHOOK_TOKEN_HEADER=x-webhook-token
AOC_WEBHOOK_TOKEN=

# ── Meta WhatsApp Cloud API (legacy, used when WHATSAPP_PROVIDER=meta) ─────────
# From Meta for Developers › your app › WhatsApp › API Setup
META_API_VERSION=v21.0
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
# A token you invent; enter the same value in the Meta webhook config screen.
META_VERIFY_TOKEN=karya-vaani-verify
# App secret, enables X-Hub-Signature-256 validation of inbound webhooks.
META_APP_SECRET=
# Set true to enforce signature checking (requires META_APP_SECRET).
COMMS_VERIFY_SIGNATURE=false

# ── Optional ──────────────────────────────────────────────────────────────
# Push every inbound message/status to this URL (other apps can subscribe).
COMMS_FORWARD_URL=
# Rolling in-memory message log size.
COMMS_STORE_LIMIT=500

# TEST ONLY: redirect every outbound message to this single number
# (so nothing reaches real workers). Leave empty in production.
WHATSAPP_TEST_RECIPIENT=919500200300
