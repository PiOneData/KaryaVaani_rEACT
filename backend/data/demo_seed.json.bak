 "knowledgeSample": [
  {
   "who": "user",
   "lang": "EN",
   "voice": true,
   "native": "If there is a fire, where should I go? Which is the assembly point?"
  },
  {
   "who": "assistant",
   "lang": "EN",
   "native": "<strong>Go to your zone's assembly point:</strong><br>1. <strong>Compressor Line</strong> → Area-A assembly point (near Gate 2)<br>2. <strong>Paint Shop</strong> → Area-C assembly point (behind the canteen)<br>3. <strong>Warehouse</strong> → Area-B assembly point<br>🚶 Do not use elevators. Report to your supervisor at the assembly point.",
   "answerText": "Go to your zone's assembly point. Compressor Line → Area-A (near Gate 2); Paint Shop → Area-C (behind the canteen); Warehouse → Area-B. Do not use elevators. Report to your supervisor at the assembly point.",
   "cites": [
    {
     "docId": "kc-309",
     "label": "Evacuation drill · notice"
    },
    {
     "docId": "kc-310",
     "label": "Emergency contacts · 24×7"
    }
   ]
  },
  {
   "who": "user",
   "lang": "EN",
   "voice": false,
   "native": "What time does the bus reach the Tambaram pickup point?"
  },
  {
   "who": "assistant",
   "lang": "EN",
   "native": "<strong>Company transport — Tambaram pickup</strong><br>• <strong>Morning shift:</strong> Route 4 bus departs Tambaram at 06:10, reaches Gate 2 by 07:05.<br>• <strong>General shift:</strong> Route 4 departs 08:00, reaches by 08:55.<br>• <strong>Late-shift drop:</strong> last bus leaves the plant at 23:15.<br>Be at the pickup point 5 minutes early — buses do not wait beyond the scheduled minute.",
   "answerText": "Company transport Route 4 serves the Tambaram pickup point. Morning shift bus departs 06:10 and reaches Gate 2 by 07:05; general shift departs 08:00, reaching by 08:55. The last late-shift drop leaves the plant at 23:15. Be at the pickup point 5 minutes early — buses do not wait beyond the scheduled minute.",
